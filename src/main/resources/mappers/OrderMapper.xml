<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ordermanagement.repository.OrderMapper">

	<resultMap id="orderResultMap" type="com.ordermanagement.model.Order">
        <id column="order_id" property="id"/>
        <result column="customer_id" property="customerId"/>
        <result column="total_price" property="totalPrice"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>
    
    <resultMap id="orderItemResultMap" type="com.ordermanagement.model.OrderItem">
        <id column="order_item_id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="product_id" property="productId"/>
        <result column="quantity" property="quantity"/>
        <result column="price" property="price"/>
        <result column="subtotal" property="subtotal"/>
    </resultMap>
    
    <insert id="createOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (
			customer_id, 
			total_price, 
			status
		) VALUES (
			#{customerId}, 
			#{totalPrice}, 
			#{status}
		)
    </insert>
    
    <insert id="createOrderItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_items (
			order_id, 
			product_id, 
			quantity, 
			price, 
			subtotal
		) VALUES (
			#{orderId}, 
			#{productId}, 
			#{quantity}, 
			#{price}, 
			#{subtotal}
		)
    </insert>
    
    <select id="getOrderById" resultMap="orderResultMap">
        SELECT 
        	order_id, 
        	customer_id, 
        	total_price, 
        	status, 
        	created_at
        FROM orders
        WHERE 
        	order_id = #{id}
    </select>
    
    <select id="getOrderItemsByOrderId" resultMap="orderItemResultMap">
        SELECT 
        	order_item_id, 
        	order_id, 
        	product_id, 
        	quantity, 
        	price, 
        	subtotal
        FROM order_items
        WHERE 
        	order_id = #{orderId}
    </select>
    
    <select id="getCustomerOrders" resultMap="orderResultMap">
        SELECT 
        	order_id, 
        	customer_id, 
        	total_price, 
        	status, 
        	created_at
        FROM orders
        WHERE 
        	customer_id = #{customerId}
    </select>
    
    <update id="cancelOrderById">
        UPDATE orders
        SET status = 'CANCELLED'
        WHERE order_id = #{id}
        AND status = 'PENDING'
    </update>

</mapper>